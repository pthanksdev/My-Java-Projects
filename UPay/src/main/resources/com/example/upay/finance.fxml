            </Label>
               <ListView fx:id="historyListView" layoutY="741.0" prefHeight="150" prefWidth="369.0" />
      
               <Label fx:id="statusLabel" layoutX="90.0" layoutY="408.0" prefHeight="17.0" prefWidth="197.0" style="-fx-text-fill: green;" wrapText="true" />
            <Button fx:id="closeButton" layoutX="324.0" layoutY="16.0" mnemonicParsing="false" onAction="#goBackToHomepage" style="-fx-background-color: #0A192F;" text="x" textFill="WHITE">
